<%- include('partials/header', { title: '500 Server Error' }) %>

<main class="flex items-center justify-center min-h-[calc(100vh-64px)] px-4">
  <div class="glass rounded-3xl shadow-2xl p-12 max-w-md w-full text-center space-y-6">
    <h1 class="text-8xl font-black text-red-400 leading-none">500</h1>
    <h2 class="text-2xl font-bold">Internal Server Error</h2>
    <p class="text-white/60 text-sm">
      Something went wrong on our end. Please try again later.
    </p>
    <% if (typeof error !== 'undefined' && error) { %>
    <p class="text-xs text-white/30 font-mono break-all"><%= error %></p>
    <% } %>
    <a href="/"
       class="inline-block px-8 py-3 rounded-full border border-white/40 text-sm font-semibold hover:bg-white/20 transition-all hover:-translate-y-0.5">
      ← Go Home
    </a>
  </div>
</main>

<%- include('partials/footer') %>
