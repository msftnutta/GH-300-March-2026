<%- include('partials/header', { title: 'Home' }) %>

<main class="flex items-center justify-center min-h-[calc(100vh-64px)] px-4 py-12">
  <div class="glass rounded-3xl shadow-2xl p-10 max-w-lg w-full text-center space-y-6">

    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">
      Hello World! 🌍
    </h1>

    <p class="text-white/70 text-sm uppercase tracking-widest">Live Info Dashboard</p>

    <div class="glass rounded-2xl p-6 space-y-4 text-left">

      <div class="flex items-center gap-3">
        <span class="text-2xl">🕐</span>
        <div>
          <p class="text-xs text-white/50 uppercase tracking-wider">Date &amp; Time</p>
          <p id="datetime" class="text-yellow-300 font-bold text-lg">Loading...</p>
        </div>
      </div>

      <div class="border-t border-white/10"></div>

      <div class="flex items-center gap-3">
        <span class="text-2xl">📍</span>
        <div>
          <p class="text-xs text-white/50 uppercase tracking-wider">Location</p>
          <p id="location" class="font-semibold text-base">Detecting...</p>
        </div>
      </div>

      <div class="border-t border-white/10"></div>

      <div class="flex items-center gap-3">
        <span class="text-2xl">🌐</span>
        <div>
          <p class="text-xs text-white/50 uppercase tracking-wider">Timezone</p>
          <p id="timezone" class="font-semibold text-base">Detecting...</p>
        </div>
      </div>

    </div>

    <a href="/weather"
       class="inline-block mt-2 px-6 py-3 rounded-full border border-white/40 text-sm font-semibold hover:bg-white/20 transition-all hover:-translate-y-0.5 active:translate-y-0">
      🌤 View Weather Forecast →
    </a>

  </div>
</main>

<%- include('partials/footer') %>
